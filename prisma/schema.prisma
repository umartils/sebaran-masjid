generator client {
  provider = "prisma-client"
  // previewFeatures = ["driverAdapters"]
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  nomorTelepon  String?
  role          String    @default("Relawan")
  image         String?
  password      String?
  userInput     String?

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Masjid {
  id                          String   @id @default(cuid())
  nama                        String
  alamat                      String
  idProvinsi                  String
  namaProvinsi                String
  idKota                      String
  namaKota                    String
  idKecamatan                 String?
  namaKecamatan               String?
  idDesa                      String?
  namaDesa                    String?
  latitude                    Float
  longitude                   Float
  kondisi                     Condition @default(RUSAK_SEDANG)
  kategori                    Category @default(Pelosok_Pedalaman)
  kapasitas                   Int?
  tahunDibangun               Int?
  budgetAwal                  Decimal? @db.Decimal(14, 2)
  luasSekarang                String?
  materialUtama               String?
  statusPerluasan             String?
  riwayatRenovasi             String?
  targetPerluasan             String?
  statusTanah                 String?
  statusListrik               String?
  waktuKerusakan              String?
  alasan                      String?
  detail                      String?
  dampakKerusakan             String?
  hambatanAktivitas           String?
  kondisiHujan                String?
  riwayatRoboh                String?
  usahaPerbaikan              String?
  riwayatMenerimaBantuan      String?
  kkMuslim                    Int?
  jumlahJamaah                String?
  avgProfesiJamaah            String?
  avgGajiJamaah               String?
  usahaJamaah                 String?
  // akses dan kondisi
  jarakKeKota                 String?
  waktuTempuhKeKota           String?
  kondisiAksesKota            String?
  kondisiAksesDesa            String?
  jenisKendaraan              String?
  hambatanAkses               String?
  gantiNama                   String?
  masjidTerdekat              String?
  aksesMasjidTerdekat         String?
  jarakKeMasjidTerdekat       String?
  alasanTidakPilihTerdekat    String?
  kelayakan                   String?
  aktivitasMasjid             String?
  jamaahSubuh                 String?
  jumlahSantri                String?
  namaPic                     String?
  jabatanPic                  String?
  kontakPic                   String?
  catatan                     String?
  statusPengajuan             BuildingStatus @default(PENDING)
  documentImgUrl              String[]
  imageUrl                    String[]
  namaRelawan                 String?
  noTelpRelawan               String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([nama])
  @@index([idProvinsi, idKota])
}

model Building {
  id                  String   @id @default(cuid())
  address             String
  provinceId          String
  provinceName        String
  regencyId           String
  name                String
  regencyName         String
  districtId          String?
  districtName        String?
  villageId           String?
  villageName         String?
  latitude            Float
  longitude           Float
  condition           Condition @default(RUSAK_SEDANG)
  capacity            Int?
  establishedYear     Int?
  initialBudget       Decimal? @db.Decimal(14, 2)
  currentArea         String?
  mainMaterial        String?
  expansionStatus     String?
  renovationHistory   String?
  expansionTarget     String?
  landStatus          String?
  notes               String?
  buildingStatus      BuildingStatus @default(PENDING)
  documentImgUrl      String[]
  imageUrl            String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([name])
  @@index([provinceId, regencyId])
}

model MasjidMN {
  id                  String   @id @default(cuid())
  name                String
  address             String
  provinceId          String
  provinceName        String
  regencyId           String
  regencyName         String
  districtId          String?
  districtName        String?
  villageId           String?
  villageName         String?
  latitude            Float
  longitude           Float
  condition           Condition @default(LAYAK)
  capacity            Int?
  establishedYear     Int?
  landStatus          String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([name])
  @@index([provinceId, regencyId])
}

model MasjidMNBaru {
  id                  String   @id @default(cuid())
  nama                String
  alamat              String
  idProvinsi          String
  namaProvinsi        String
  idKota              String
  namaKota            String
  idKecamatan         String
  namaKecamatan       String
  idDesa              String
  namaDesa            String
  latitude            Float
  longitude           Float
  kapasitas           Int?
  tahunDibangun       Int?
  statusTanah         String?
  catatan             String?
  kondisi             Condition @default(RUSAK_SEDANG)
  kategori                    Category @default(Pelosok_Pedalaman)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([nama])
  @@index([idProvinsi, idKota])
}

enum Condition {
  RUSAK_BERAT
  RUSAK_SEDANG
  RUSAK_RINGAN
  LAYAK
}

enum Role {
  Relawan
  Admin
}

enum BuildingStatus {
  APPROVED
  PENDING
  REJECTED
  DELETED
}

enum Category {
  Pelosok_Pedalaman
  Muslim_Minoritas
  Kampung_Mualaf
  Terdampak_Bencana
}

